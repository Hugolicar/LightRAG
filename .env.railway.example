# LightRAG Railway — env vars template
# Copie este arquivo e defina cada variável via `railway variables set <KEY>=<value>`
# OU cole direto no dashboard Railway (Variables tab).

# === REQUIRED: LLM (gera texto + extrai entidades) ===
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.openai.com/v1
LLM_BINDING_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
MAX_ASYNC_LLM=4
KEYWORD_MAX_ASYNC_LLM=4
QUERY_MAX_ASYNC_LLM=4

# === REQUIRED: Embedding (vetoriza chunks) ===
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_BINDING_API_KEY=sk-...                   # se igual ao LLM, deixe vazio
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_BATCH_NUM=32

# === Server ===
HOST=0.0.0.0
PORT=9621                                          # Railway injeta automaticamente; este é fallback
WEBUI_TITLE='LightRAG Hugo'
WEBUI_DESCRIPTION='Multimodal RAG — fork HKUDS'
ENABLE_LLM_CACHE=false

# === MULTIMODAL (RAG-Anything-equivalent, nativo v1.5.4+) ===
# Parser routing: roteia PDFs pra MinerU (reconhece texto + imagem + tabela + equação)
# Demais formatos vão pro parser nativo (tex/text) ou legacy (csv/json/etc).
LIGHTRAG_PARSER=*.pdf:mineru;*.docx:mineru;*.pptx:mineru;*.xlsx:mineru;*:native-tex

# MinerU local mode (baixa modelos no primeiro uso; pesado)
MINERU_API_MODE=local
MINERU_LOCAL_ENDPOINT=http://127.0.0.1:8000          # se rodar MinerU via sidecar
MINERU_LOCAL_BACKEND=hybrid-auto-engine
MINERU_LOCAL_PARSE_METHOD=auto
# MINERU_ENABLE_TABLE=true                          # já é default em v1.5.4

# Vision model (VLM) — opcional, melhora query multimodal
VLM_PROCESS_ENABLE=false                             # true quando quiser VLM-enhanced query
VLM_BINDING=openai
VLM_BINDING_HOST=https://api.openai.com/v1
VLM_BINDING_API_KEY=sk-...
VLM_MODEL=gpt-4o


# === RAG-Anything bridge (opt-in, vendored) ===
# Mantém o deploy atual inalterado enquanto false. Ative só depois do PR deployar.
RAGANYTHING_ENABLE=false
RAGANYTHING_PARSER=mineru
RAGANYTHING_PARSE_METHOD=auto
RAGANYTHING_IMAGE_PROCESSING=true
RAGANYTHING_TABLE_PROCESSING=true
RAGANYTHING_EQUATION_PROCESSING=true
# RAGANYTHING_WORKING_DIR=/app/data/rag_storage
# RAGANYTHING_OUTPUT_DIR=/app/data/rag_storage/raganything_output
# Para caption/query com imagem, habilite também o bloco VLM_* acima.

# === Storage defaults (JsonKVStorage + NanoVectorDBStorage, sem banco externo) ===
LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage

# === Security (recomendado: proteger API pública com chave) ===
LIGHTRAG_API_KEY=troque-por-uma-string-aleatoria-32chars
WHITELIST_PATHS=/health
AUTH_ACCOUNTS=hugo:outra-senha-aqui

# === Token secret pra JWT (opcional, pra login web) ===
# TOKEN_SECRET=outro-segredo-aleatorio-32chars
# TOKEN_EXPIRE_HOURS=48
# GUEST_TOKEN_EXPIRE_HOURS=24
